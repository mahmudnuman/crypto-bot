# ── CryptoPredictBot .gitignore ─────────────────────────────────────

# Raw market data (large binary files — re-downloadable)
data/raw/
*.parquet

# Feature cache (re-buildable in 30 min)
cache/features/
cache/checkpoints/*.pkl

# saved_models/ — intentionally tracked so Kaggle models sync to local PC via git pull
# (each model ~4MB × 25 coins = ~100MB total — within GitHub limits)

# Python
__pycache__/
*.py[cod]
*.pyo
.Python
*.egg-info/
dist/
build/
.eggs/

# Environments
.env
.venv
env/
venv/

# Logs (keep small summary, ignore big logs)
cache/*.txt
cache/*.json
!cache/training_report.json

# Jupyter
.ipynb_checkpoints/
*.ipynb

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db
desktop.ini

# Test artifacts
test_ensemble.py
